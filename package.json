{
  "name": "crx-extractor",
  "version": "2.0.0",
  "description": "CRX Extractor — Extract Chrome Extension source code from .crx files (Vite + ES6)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{js,css,html}\" \"*.{js,json,md}\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vladignatyev/crx-extractor.git"
  },
  "author": "Vladimir Ignatev",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/vladignatyev/crx-extractor/issues"
  },
  "homepage": "https://github.com/vladignatyev/crx-extractor#readme",
  "private": true,
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
